# Decentralized-BMP Backend Configuration
# Copy this file to .env and customize the values below.

# REQUIRED: Set a strong, unique admin key for programmatic API access.
ADMIN_KEY=changeme-set-a-real-key-here

# CORS allowed origins (comma-separated). Set to your actual domain.
ALLOWED_ORIGINS=https://backend.yourdomain.xyz

# Version strings returned to launchers and game servers for update checks.
LAUNCHER_VERSION=2.7.0
SERVER_VERSION=3.9.1
